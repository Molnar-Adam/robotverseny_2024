<?xml version="1.0"?>
<!--
ROS System Test: full pipeline

    /scan -> pid_error.py -> /error -> control.py -> /cmd_vel -> path_and_steering.cpp
    /odom -> path_and_steering.cpp -> /marker_path + /marker_text + /marker_steering
-->
<launch>
    <node pkg="megoldas_gyor24" type="pid_error.py" name="pid_error" output="screen" />

    <node pkg="megoldas_gyor24" type="control.py" name="control" output="screen">
        <param name="kp" value="10.0" />
        <param name="kd" value="0.01" />
        <param name="ki" value="0.0" />
        <param name="kp_vel" value="42.0" />
        <param name="servo_offset" value="0.314159" />
    </node>

    <node pkg="megoldas_gyor24" type="path_and_steering" name="path_and_steering" output="screen">
        <param name="path_size" value="100" />
        <param name="publish_steer_marker" value="true" />
        <param name="marker_color" value="gradient" />
    </node>

    <test
        test-name="system_pipeline_test"
        pkg="megoldas_gyor24"
        type="test_system_pipeline.py"
        launch-prefix="python3"
        time-limit="90.0" />
</launch>